{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "strict": false,
    "noEmit": true,
    "types": ["node"],
    "allowJs": false,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["agents/**/*.ts"]
}
